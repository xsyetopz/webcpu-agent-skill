{
	"name": "webcpu-agent-skill",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"description": "All-agent skill/plugin for @xsyetopz/easel CPU Canvas2D rendering.",
	"license": "MIT",
	"scripts": {
		"clean": "node scripts/clean.mjs",
		"extract-api": "node scripts/extract-api.mjs",
		"generate": "node scripts/generate.mjs",
		"package": "node scripts/package.mjs",
		"pack:archive": "node scripts/archive.mjs",
		"validate": "node scripts/validate.mjs --source-clean",
		"validate:source": "node scripts/validate.mjs --source-clean",
		"validate:package": "node scripts/validate.mjs --package",
		"check": "node scripts/extract-api.mjs && node scripts/generate.mjs && node scripts/generate-agent-surfaces.mjs && node scripts/generate-llms.mjs && node scripts/package.mjs && node scripts/validate.mjs --package && bun run biome:check && bun run typecheck && bun run deno:check",
		"test": "node scripts/validate.mjs --source-clean",
		"biome:check": "bunx biome check .",
		"biome:lint": "bunx biome lint .",
		"biome:format": "bunx biome format . --write",
		"typecheck": "tsc --noEmit",
		"deno:check": "node scripts/check-deno.mjs",
		"generate:llms": "node scripts/generate-llms.mjs",
		"generate:agents": "node scripts/generate-agent-surfaces.mjs",
		"templates:check": "node scripts/check-templates.mjs"
	},
	"dependencies": {
		"@xsyetopz/easel": "0.4.5"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"bun-types": "^1.3.12",
		"typescript": "6.0.3",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"astro": "^6.1.7",
		"vite": "^8.0.8"
	}
}
